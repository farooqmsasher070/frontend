VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=your_user_pool_id
VITE_COGNITO_USER_POOL_CLIENT_ID=your_client_id
VITE_COGNITO_OAUTH_DOMAIN=your-cognito-domain.auth.us-east-1.amazoncognito.com
VITE_COGNITO_OAUTH_REDIRECT_SIGN_IN=http://localhost:5173/
VITE_COGNITO_OAUTH_REDIRECT_SIGN_OUT=http://localhost:5173/
VITE_COGNITO_OAUTH_RESPONSE_TYPE=code
VITE_COGNITO_OAUTH_SCOPES=openid,email,profile

# If you need multiple redirect URLs, separate them with commas:
# VITE_COGNITO_OAUTH_REDIRECT_SIGN_IN=http://localhost:5173/,https://yourapp.com/
# VITE_COGNITO_OAUTH_REDIRECT_SIGN_OUT=http://localhost:5173/,https://yourapp.com/
